{
  "manifest_version": 3,
  "name": "VibeX - Instagram Enhanced Controls",
  "version": "2.13.0",
  "description": "Advanced volume control, video playback features, song recognition, and download capability for Instagram",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://stingy-rachele-naeem-5b43a3bb.koyeb.app/*",
    "https://c435d6c1-938e-4f89-a2c9-1d9be952b4ff-00-1kiowiwrfwvgy.spock.replit.dev/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css",
        "song-styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "welcome.html",
        "update.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "naeem58902@gmail.com",
      "strict_min_version": "140.0"
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}